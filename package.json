  "repository": {
    "type": "git",
    "url": "https://github.com/Serhatcck/mobile-security-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Serhatcck/mobile-security-mcp/issues"
  },
  "homepage": "https://github.com/Serhatcck/mobile-security-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "adm-zip": "^0.5.10",
    "plist": "^3.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.11.5",
